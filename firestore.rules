rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isValidUserPublic(data) {
      return data.keys().hasOnly(['displayName']) && 
             data.displayName is string && 
             data.displayName.size() <= 100;
    }
    
    match /users/{userId}/public {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(userId) &&
                   isValidId(userId) &&
                   isValidUserPublic(incoming());
      allow update: if isOwner(userId) &&
                   isValidUserPublic(incoming()) &&
                   incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
    }
    
    function isValidUserPrivate(data) {
      return data.keys().hasOnly(['email']) &&
             data.email is string && data.email.size() <= 200;
    }

    match /users/{userId}/private/info {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) &&
                   isValidId(userId) &&
                   isValidUserPrivate(incoming());
      allow update: if isOwner(userId) &&
                   isValidUserPrivate(incoming()) &&
                   incoming().diff(existing()).affectedKeys().hasOnly(['email']);
    }

    function isValidFavorite(data) {
      return data.keys().hasOnly(['songId']) &&
             data.songId is string && data.songId.size() <= 100;
    }

    match /users/{userId}/favorites/{songId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) && (resource.data.userId == request.auth.uid || true); 
      allow create: if isOwner(userId) &&
                   isValidId(userId) && isValidId(songId) &&
                   isValidFavorite(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
